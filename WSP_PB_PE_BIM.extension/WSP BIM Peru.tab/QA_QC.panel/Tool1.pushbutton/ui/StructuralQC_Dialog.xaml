<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Structural QC – WSP BIM Peru"
        Height="420" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False"
        Topmost="True">

	<Grid Margin="14">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Descripción -->
		<Border Grid.Row="0" Background="#FFF3F5F7" BorderBrush="#FFCBD3DC" BorderThickness="1" CornerRadius="6" Padding="10">
			<TextBlock TextWrapping="Wrap" FontSize="13">
				<Run FontWeight="SemiBold" Text="Propósito:"/>
				<LineBreak/>
				<Run Text="Revisión rápida de QA/QC para elementos estructurales seleccionados (muros/columnas)."/>
				<LineBreak/>
				<Run Text="Genera un reporte de incidencias por consola y un resumen final."/>
			</TextBlock>
		</Border>

		<!-- Contenido -->
		<Grid Grid.Row="1" Margin="0,12,0,12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Tipos de elementos -->
			<GroupBox Grid.Column="0" Header="Tipos de elementos" Padding="10" Margin="0,0,8,0">
				<StackPanel>
					<CheckBox x:Name="chkWalls" Content="Muros estructurales" IsChecked="True" Margin="0,0,0,6"/>
					<CheckBox x:Name="chkColumns" Content="Columnas estructurales" IsChecked="True"/>
				</StackPanel>
			</GroupBox>

			<!-- Checks -->
			<GroupBox Grid.Column="1" Header="Checks" Padding="10" Margin="8,0,0,0">
				<StackPanel>
					<CheckBox x:Name="chkComments" Content="Comments no vacío" IsChecked="True" Margin="0,0,0,6"/>
					<CheckBox x:Name="chkLevel" Content="Level asignado" IsChecked="True"/>
				</StackPanel>
			</GroupBox>
		</Grid>

		<!-- Botones -->
		<DockPanel Grid.Row="2" LastChildFill="False">
			<TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#FF6B7280"
                       Text="WSP Perú – Herramientas BIM internas" />
			<StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
				<Button x:Name="btnRun" Content="Ejecutar" Width="100" Height="30" Margin="0,0,8,0" IsDefault="True"/>
				<Button x:Name="btnCancel" Content="Cancelar" Width="100" Height="30" IsCancel="True"/>
			</StackPanel>
		</DockPanel>
	</Grid>
</Window>